{
  "name": "@openharness/sandbox",
  "version": "0.1.0",
  "description": "Open Harness CLI and sandbox tools — Docker containers, git worktrees, heartbeats",
  "type": "module",
  "bin": {
    "openharness": "./dist/src/cli/index.js",
    "oh": "./dist/src/cli/index.js",
    "heartbeat-daemon": "./dist/src/cli/heartbeat-daemon.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/src/cli/index.js dist/src/cli/heartbeat-daemon.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "ci": "eslint src/ && prettier --check 'src/**/*.ts' && vitest run"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "croner": "^9.1.0",
    "typebox": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
