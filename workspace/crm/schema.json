{
  "version": "1",
  "file": "crm/leads.csv",
  "delimiter": ",",
  "quote": "\"",
  "encoding": "utf-8",
  "primary_key": "id",
  "columns": [
    { "name": "id",                    "type": "string",   "required": true,  "pattern": "^L-[0-9]{6}$" },
    { "name": "company",               "type": "string",   "required": true,  "max_length": 120 },
    { "name": "website",               "type": "string",   "required": false, "pattern": "^[a-z0-9.-]+\\.[a-z]{2,}$" },
    { "name": "city",                  "type": "string",   "required": false },
    { "name": "state",                 "type": "enum",     "required": true,  "values": ["NC","SC","VA","GA","TN","other"] },
    { "name": "vertical",              "type": "enum",     "required": true,  "values": ["vertical_3pl","vertical_food_bev","vertical_furniture","vertical_brewery","vertical_biotech_pharma","vertical_industrial_mfg","vertical_agriculture","vertical_textile","vertical_other"] },
    { "name": "tier",                  "type": "enum",     "required": false, "values": ["A","B","C"] },
    { "name": "employee_count_band",   "type": "enum",     "required": false, "values": ["1-10","11-50","51-200","201-1000","1000+","unknown"] },
    { "name": "source",                "type": "enum",     "required": true,  "values": ["inbound","referral","list_import","event","manual","reactivation","research"] },
    { "name": "contact_name",          "type": "string",   "required": false },
    { "name": "contact_title",         "type": "string",   "required": false },
    { "name": "contact_email",         "type": "string",   "required": false, "pattern": "^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$" },
    { "name": "contact_email_status",  "type": "enum",     "required": false, "values": ["unverified","valid","risky","invalid","bounced"] },
    { "name": "contact_phone",         "type": "string",   "required": false, "pattern": "^\\+?[0-9 ()-]{7,}$" },
    { "name": "contact_linkedin",      "type": "string",   "required": false },
    { "name": "budget_signal",         "type": "enum",     "required": false, "values": ["none","implied","confirmed","unknown"] },
    { "name": "monthly_spend_band",    "type": "enum",     "required": false, "values": ["under_1k","1k_5k","5k_25k","25k_100k","over_100k","unknown"] },
    { "name": "authority_level",       "type": "enum",     "required": false, "values": ["user","influencer","decision_maker","gatekeeper","unknown"] },
    { "name": "need_type",             "type": "enum",     "required": false, "values": ["replace_incumbent","add_capacity","new_site","one_time","compliance","unknown"] },
    { "name": "pain_primary",          "type": "enum",     "required": false, "values": ["inconsistent_delivery","price_increase","quality_defects","pallet_shortage","damaged_product","ispm15_compliance","sustainability_mandate","supplier_consolidation","no_stated_pain","unknown"] },
    { "name": "pain_implication",      "type": "enum",     "required": false, "values": ["stockout","overtime_labor","damaged_goods","customs_fine","margin_squeeze","none_stated","unknown"] },
    { "name": "timing",                "type": "enum",     "required": false, "values": ["now","within_30d","30_90d","90_180d","no_timeline","unknown"] },
    { "name": "contract_status",       "type": "enum",     "required": false, "values": ["no_contract","rolling","annual","multi_year","unknown"] },
    { "name": "pallet_interest",       "type": "enum_set", "required": false, "delimiter": "|", "values": ["gma_48x40_new","gma_48x40_recycled","heat_treated_ispm15","block_pallet","stringer_pallet","custom_wood","plastic_pallet","cp_series","presswood_molded","eur_epal","pallet_recycling_service","pallet_management_program"] },
    { "name": "est_volume_weekly",     "type": "integer",  "required": false, "min": 0 },
    { "name": "current_supplier",      "type": "string",   "required": false, "max_length": 80 },
    { "name": "supplier_satisfaction", "type": "enum",     "required": false, "values": ["happy","neutral","unhappy","actively_shopping","unknown"] },
    { "name": "primary_lane",          "type": "string",   "required": false, "max_length": 80 },
    { "name": "export_exposure",       "type": "enum",     "required": false, "values": ["none","occasional","regular","primary","unknown"] },
    { "name": "lane_hint",             "type": "enum_set", "required": false, "delimiter": "|", "values": ["i85","i40","i77","i95","i26","us220_i73","port_wilm","other"] },
    { "name": "stage",                 "type": "enum",     "required": true,  "default": "new", "values": ["new","researched","contacted","engaged","qualified","quoted","closed_won","closed_lost"] },
    { "name": "fit_score",             "type": "integer",  "required": false, "min": 0, "max": 100 },
    { "name": "owner",                 "type": "string",   "required": true,  "default": "sdr-pallet" },
    { "name": "next_action",           "type": "enum",     "required": false, "values": ["research","email_1","email_2","email_3","email_4","email_6","email_8","call","linkedin","wait_reply","discovery","handoff","reactivate","none"] },
    { "name": "next_action_date",      "type": "date",     "required": false, "format": "YYYY-MM-DD" },
    { "name": "last_touch_date",       "type": "date",     "required": false, "format": "YYYY-MM-DD" },
    { "name": "touches_count",         "type": "integer",  "required": false, "min": 0, "default": 0 },
    { "name": "dq_reason",             "type": "enum",     "required": false, "values": ["","territory_out_of_bounds","volume_below_floor","competitor","wood_incompatible","opt_out","undeliverable","hostile","contract_locked","timing_not_now","lost_to_competitor","price","ghosted_post_quote","no_reply_exhausted","bant_failed","other"] },
    { "name": "notes_ref",             "type": "string",   "required": false, "pattern": "^crm/drafts/L-[0-9]{6}/.+" },
    { "name": "created_at",            "type": "datetime", "required": true,  "format": "YYYY-MM-DDTHH:MM:SSZ", "auto": "now" },
    { "name": "updated_at",            "type": "datetime", "required": true,  "format": "YYYY-MM-DDTHH:MM:SSZ", "auto": "now_on_write" }
  ],
  "invariants": [
    "id is unique",
    "stage value is listed in stages.json.states",
    "every row write appends a corresponding entry to history.csv",
    "terminal stages (closed_won, closed_lost) freeze the row against updates except event=note"
  ],
  "notes": [
    "Conflict resolutions C1-C9 from plan encoded here.",
    "Vertical enum owned by spec 03; pallet_interest enum owned by spec 02; stage enum + qual_* columns owned by spec 01.",
    "pallet_interest and lane_hint are enum_set — pipe-delimited in a single CSV cell."
  ]
}
