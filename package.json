{
  "name": "open-harness",
  "version": "0.1.0",
  "private": true,
  "description": "Open Harness — AI Agent Sandbox Orchestrator",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "setup": "pnpm install && pnpm -r --if-present run build && pnpm link --global ./packages/sandbox",
    "build": "pnpm -r --if-present run build",
    "test": "pnpm -r --if-present run test",
    "lint": "pnpm -r --if-present run lint",
    "format:check": "pnpm -r --if-present run format:check",
    "format": "pnpm -r --if-present run format",
    "docs:build": "pnpm --dir apps/docs build",
    "docs:dev": "pnpm --dir apps/docs start",
    "docs:serve": "pnpm --dir apps/docs serve"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "overrides": {
      "d3-array": "^3.2.0",
      "d3-shape": "^3.2.0",
      "d3-path": "^3.1.0",
      "webpack": "5.98.0"
    }
  }
}
