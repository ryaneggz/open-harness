{
  "name": "open-harness",
  "version": "0.1.0",
  "private": true,
  "description": "Open Harness — AI Agent Sandbox Orchestrator",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "setup": "pnpm install && pnpm -r run build && pnpm link --global ./packages/sandbox",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "format:check": "pnpm -r run format:check",
    "format": "pnpm -r run format"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "overrides": {
      "d3-array": "^3.2.0",
      "d3-shape": "^3.2.0",
      "d3-path": "^3.1.0"
    }
  }
}
