# Freshness guard: block commits where one side of an .original.md pair is staged without the other
staged=$(git diff --cached --name-only)
for orig in $(echo "$staged" | grep '\.original\.md$'); do
  compressed=$(echo "$orig" | sed 's/\.original\.md$/.md/')
  if ! echo "$staged" | grep -qx "$compressed"; then
    echo "FRESHNESS GUARD: $orig is staged but $compressed is not."
    echo "  Run /compress to regenerate the compressed version, or stage both files."
    exit 1
  fi
done
for comp in $(echo "$staged" | grep -v '\.original\.md$' | grep 'workspace/.*\.md$'); do
  original=$(echo "$comp" | sed 's/\.md$/.original.md/')
  if [ -f "$original" ] && ! echo "$staged" | grep -qx "$original"; then
    echo "FRESHNESS GUARD: $comp is staged but $original is not."
    echo "  Edit the .original.md source and run /compress, or stage both files."
    exit 1
  fi
done

cd packages/sandbox && pnpm exec lint-staged && pnpm run build && pnpm run test
