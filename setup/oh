#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

SUPERVISOR_NAME="${OH_SUPERVISOR_NAME:-oh-supervisor}"
SUPERVISOR_IMAGE="${OH_SUPERVISOR_IMAGE:-open-harness-supervisor:latest}"
SUPERVISOR_MARKER="/opt/open-harness/.supervisor-ready"
SUPERVISOR_PROJECT_ROOT="${OH_REPO_ROOT:-$REPO_ROOT}"
HOST_HOME_PATH="${OH_HOST_HOME:-${HOME:-}}"

usage() {
  cat <<'EOF'
Open Harness CLI

Usage:
  oh install
  oh bootstrap
  oh supervisor up
  oh supervisor down
  oh supervisor shell
  oh supervisor status
  oh create <name> [-i] [-w PATH] [--docker] [--tag TAG] [--base-branch BRANCH] [--branch BRANCH]
  oh shell <name>
  oh stop <name>
  oh clean <name>
  oh build <name>
  oh run <name>
  oh rebuild <name>
  oh list
  oh heartbeat <name>
  oh heartbeat-stop <name>
  oh heartbeat-status <name>
  oh heartbeat-migrate <name>
  oh help

Options for create:
  -i, --interactive     Prompt for missing values
  -w, --workspace PATH  Mount an external host path at /workspace
  --docker              Enable Docker socket mount
  --tag TAG             Image tag (default: latest)
  --base-branch BRANCH  Base branch for default worktree mode
  --branch BRANCH       Branch name for default worktree mode

Behavior:
  - The same `oh` sandbox commands run on the host and inside the supervisor
  - On the host, `oh` is a small bootstrap/proxy shim that forwards sandbox commands into the supervisor
  - Sandbox lifecycle commands auto-bootstrap a supervisor container if needed
  - By default, create uses a git worktree workspace under .worktrees/<name>
  - If --workspace PATH is provided, that host path is mounted at /workspace instead
EOF
}

run_make() {
  (cd "$REPO_ROOT" && make "$@")
}

require_name() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    echo "Error: sandbox name is required." >&2
    exit 1
  fi
}

resolve_path() {
  local path="$1"
  if [[ -z "$path" ]]; then
    return 0
  fi

  local dir base
  dir="$(dirname "$path")"
  base="$(basename "$path")"
  mkdir -p "$dir"
  dir="$(cd "$dir" && pwd)"
  printf '%s/%s\n' "$dir" "$base"
}

prompt_yes_no() {
  local prompt="$1"
  local default="${2:-y}"
  local answer

  if [[ "$default" == "y" ]]; then
    read -rp "$prompt [Y/n]: " answer
    [[ -z "$answer" || "$answer" =~ ^[Yy]$ ]]
  else
    read -rp "$prompt [y/N]: " answer
    [[ "$answer" =~ ^[Yy]$ ]]
  fi
}

seed_workspace() {
  local dest="$1"
  mkdir -p "$dest" "$dest/heartbeats" "$dest/.claude/agents" "$dest/.claude/skills" "$dest/.pi/extensions"

  [[ -e "$dest/AGENTS.md" ]] || cp "$REPO_ROOT/AGENTS.md" "$dest/AGENTS.md"
  [[ -e "$dest/SOUL.md" ]] || cp "$REPO_ROOT/SOUL.md" "$dest/SOUL.md"
  [[ -e "$dest/MEMORY.md" ]] || cp "$REPO_ROOT/MEMORY.md" "$dest/MEMORY.md"
  [[ -e "$dest/heartbeats.conf" ]] || cp "$REPO_ROOT/heartbeats.conf" "$dest/heartbeats.conf"
  [[ -e "$dest/heartbeats/default.md" ]] || cp "$REPO_ROOT/heartbeats/default.md" "$dest/heartbeats/default.md"
  [[ -e "$dest/.pi/banner.json" ]] || cp "$REPO_ROOT/.pi/banner.json" "$dest/.pi/banner.json"
  [[ -e "$dest/.pi/extensions/custom-banner.ts" ]] || cp "$REPO_ROOT/.pi/extensions/custom-banner.ts" "$dest/.pi/extensions/custom-banner.ts"

  for file in agent-builder.md command-builder.md skill-builder.md; do
    [[ -e "$dest/.claude/agents/$file" ]] || cp "$REPO_ROOT/.claude/agents/$file" "$dest/.claude/agents/$file"
  done

  [[ -e "$dest/CLAUDE.md" ]] || ln -s AGENTS.md "$dest/CLAUDE.md"
  [[ -e "$dest/.codex" ]] || ln -s .claude "$dest/.codex"
}

cmd_install() {
  chmod +x "$REPO_ROOT/setup/oh"

  local global_target="/usr/local/bin/oh"
  local user_bin="$HOME/.local/bin"
  local user_target="$user_bin/oh"

  if [[ -w /usr/local/bin ]]; then
    ln -sf "$REPO_ROOT/setup/oh" "$global_target"
    echo "Installed: $global_target -> $REPO_ROOT/setup/oh"
    return
  fi

  if sudo -n true 2>/dev/null; then
    sudo ln -sf "$REPO_ROOT/setup/oh" "$global_target"
    echo "Installed: $global_target -> $REPO_ROOT/setup/oh"
    return
  fi

  echo "/usr/local/bin is not writable and passwordless sudo is unavailable."

  if [[ -t 0 && -t 1 ]]; then
    echo "Choose an install location:"
    echo "  1) ~/.local/bin/oh (recommended)"
    echo "  2) Try sudo install to /usr/local/bin/oh"
    echo "  3) Cancel"

    local choice
    read -rp "Install method [1/2/3]: " choice

    case "${choice:-1}" in
      2)
        if sudo ln -sf "$REPO_ROOT/setup/oh" "$global_target"; then
          echo "Installed: $global_target -> $REPO_ROOT/setup/oh"
          return
        fi
        echo "Falling back to ~/.local/bin/oh"
        ;;
      3)
        echo "Cancelled."
        exit 1
        ;;
    esac
  fi

  mkdir -p "$user_bin"
  ln -sf "$REPO_ROOT/setup/oh" "$user_target"
  echo "Installed: $user_target -> $REPO_ROOT/setup/oh"

  if [[ ":$PATH:" != *":$user_bin:"* ]]; then
    echo ""
    echo "Add ~/.local/bin to your PATH if needed:"
    echo '  export PATH="$HOME/.local/bin:$PATH"'
  fi
}

require_docker() {
  if ! command -v docker >/dev/null 2>&1; then
    echo "Error: docker is required on the host for supervisor bootstrap." >&2
    exit 1
  fi

  if ! docker info >/dev/null 2>&1; then
    echo "Error: Docker daemon is not reachable. Start Docker and try again." >&2
    exit 1
  fi
}

supervisor_exists() {
  docker inspect "$SUPERVISOR_NAME" >/dev/null 2>&1
}

supervisor_running() {
  [[ "$(docker inspect -f '{{.State.Running}}' "$SUPERVISOR_NAME" 2>/dev/null || true)" == "true" ]]
}

supervisor_exec() {
  local user="$1"
  shift

  local docker_args=(exec --user "$user")
  if [[ -t 0 && -t 1 ]]; then
    docker_args+=( -it )
  fi

  docker_args+=(
    -e HOME=/home/sandbox
    -e USER=sandbox
    -e PROJECT_ROOT="$SUPERVISOR_PROJECT_ROOT"
    -e INSTALL_ROOT=/opt/open-harness/install
    -e OH_SUPERVISOR=1
    -e OH_REPO_ROOT="$SUPERVISOR_PROJECT_ROOT"
    -e OH_HOST_HOME="$HOST_HOME_PATH"
    -w "$SUPERVISOR_PROJECT_ROOT"
    "$SUPERVISOR_NAME"
  )

  docker "${docker_args[@]}" "$@"
}

build_supervisor_image() {
  chmod +x "$REPO_ROOT/setup/oh"
  docker build -f "$REPO_ROOT/setup/docker/Dockerfile" -t "$SUPERVISOR_IMAGE" "$REPO_ROOT"
}

create_supervisor_container() {
  local docker_args=(
    run -d
    --name "$SUPERVISOR_NAME"
    --label open-harness.role=supervisor
    --restart unless-stopped
    -e PROJECT_ROOT="$REPO_ROOT"
    -e INSTALL_ROOT=/opt/open-harness/install
    -e OH_SUPERVISOR=1
    -e OH_REPO_ROOT="$REPO_ROOT"
    -e OH_HOST_HOME="$HOST_HOME_PATH"
    -w "$REPO_ROOT"
    -v /var/run/docker.sock:/var/run/docker.sock
    -v "$REPO_ROOT:$REPO_ROOT"
  )

  if [[ -n "$HOST_HOME_PATH" && -d "$HOST_HOME_PATH" ]]; then
    docker_args+=( -v "$HOST_HOME_PATH:$HOST_HOME_PATH" )
  fi

  if [[ -f "$HOST_HOME_PATH/.gitconfig" ]]; then
    docker_args+=( -v "$HOST_HOME_PATH/.gitconfig:/home/sandbox/.gitconfig:ro" )
  fi

  if [[ -d "$HOST_HOME_PATH/.ssh" ]]; then
    docker_args+=( -v "$HOST_HOME_PATH/.ssh:/home/sandbox/.ssh:ro" )
  fi

  if [[ -n "${SSH_AUTH_SOCK:-}" && -S "${SSH_AUTH_SOCK:-}" ]]; then
    docker_args+=( -v "$SSH_AUTH_SOCK:$SSH_AUTH_SOCK" -e "SSH_AUTH_SOCK=$SSH_AUTH_SOCK" )
  fi

  docker "${docker_args[@]}" "$SUPERVISOR_IMAGE" sleep infinity >/dev/null
}

provision_supervisor() {
  if docker exec --user root "$SUPERVISOR_NAME" test -f "$SUPERVISOR_MARKER" >/dev/null 2>&1; then
    return
  fi

  echo "Provisioning supervisor sandbox..."
  docker exec --user root "$SUPERVISOR_NAME" bash -lc "/opt/open-harness/install/setup.sh --non-interactive && touch '$SUPERVISOR_MARKER'"
}

ensure_supervisor() {
  require_docker

  if supervisor_running; then
    provision_supervisor
    return
  fi

  if supervisor_exists; then
    docker start "$SUPERVISOR_NAME" >/dev/null
    provision_supervisor
    return
  fi

  echo "Bootstrapping supervisor sandbox: $SUPERVISOR_NAME"
  build_supervisor_image
  create_supervisor_container
  provision_supervisor
}

cmd_bootstrap() {
  ensure_supervisor
  echo "Supervisor ready: $SUPERVISOR_NAME"
}

cmd_supervisor() {
  local subcmd="${1:-status}"
  shift || true

  case "$subcmd" in
    up)
      cmd_bootstrap
      ;;
    down|stop)
      require_docker
      if supervisor_exists; then
        docker rm -f "$SUPERVISOR_NAME" >/dev/null
        echo "Supervisor removed: $SUPERVISOR_NAME"
      else
        echo "Supervisor not running: $SUPERVISOR_NAME"
      fi
      ;;
    shell)
      ensure_supervisor
      supervisor_exec sandbox bash --login
      ;;
    status)
      require_docker
      if supervisor_exists; then
        docker ps -a --filter "name=^${SUPERVISOR_NAME}$" --format "table {{.Names}}\t{{.Status}}\t{{.Image}}"
        if docker exec --user root "$SUPERVISOR_NAME" test -f "$SUPERVISOR_MARKER" >/dev/null 2>&1; then
          echo "Provisioned: yes"
        else
          echo "Provisioned: no"
        fi
      else
        echo "Supervisor not running: $SUPERVISOR_NAME"
      fi
      ;;
    *)
      echo "Unknown supervisor command: $subcmd" >&2
      exit 1
      ;;
  esac
}

cmd_create() {
  local name=""
  local workspace=""
  local interactive=false
  local docker=false
  local tag="latest"
  local base_branch=""
  local branch=""
  local seed="auto"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -i|--interactive)
        interactive=true
        ;;
      -w|--workspace)
        shift
        workspace="${1:-}"
        ;;
      --docker)
        docker=true
        ;;
      --tag)
        shift
        tag="${1:-latest}"
        ;;
      --base-branch)
        shift
        base_branch="${1:-}"
        ;;
      --branch)
        shift
        branch="${1:-}"
        ;;
      --seed)
        seed="yes"
        ;;
      --no-seed)
        seed="no"
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        if [[ -z "$name" ]]; then
          name="$1"
        else
          echo "Unknown argument: $1" >&2
          exit 1
        fi
        ;;
    esac
    shift || true
  done

  if [[ "$interactive" == true ]]; then
    if [[ -z "$name" ]]; then
      read -rp "Sandbox name: " name
    fi

    read -rp "External workspace path (blank = use default worktree): " prompt_workspace
    if [[ -n "$prompt_workspace" ]]; then
      workspace="$prompt_workspace"
    fi

    if prompt_yes_no "Enable Docker socket access?" "n"; then
      docker=true
    fi
  fi

  require_name "$name"

  if [[ -n "$workspace" ]]; then
    workspace="$(resolve_path "$workspace")"

    if [[ -n "$HOST_HOME_PATH" && "$workspace" != "$REPO_ROOT" && "$workspace" != "$REPO_ROOT"/* && "$workspace" != "$HOST_HOME_PATH" && "$workspace" != "$HOST_HOME_PATH"/* ]]; then
      echo "Error: external workspace '$workspace' is outside the supervisor-mounted paths." >&2
      echo "Use a path under '$HOST_HOME_PATH' or under the repo root, or extend the supervisor mounts first." >&2
      exit 1
    fi

    mkdir -p "$workspace"

    if [[ "$seed" == "auto" && "$interactive" == true && ! -e "$workspace/AGENTS.md" ]]; then
      if prompt_yes_no "Seed default workspace files into $workspace?" "y"; then
        seed="yes"
      else
        seed="no"
      fi
    fi

    if [[ "$seed" == "yes" ]]; then
      seed_workspace "$workspace"
    fi
  fi

  local args=("NAME=$name" "TAG=$tag")
  [[ "$docker" == true ]] && args+=("DOCKER=true")
  [[ -n "$workspace" ]] && args+=("WORKSPACE=$workspace")
  [[ -n "$base_branch" ]] && args+=("BASE_BRANCH=$base_branch")
  [[ -n "$branch" ]] && args+=("BRANCH=$branch")

  run_make "${args[@]}" quickstart
}

cmd_named_target() {
  local target="$1"
  shift
  local name="${1:-}"
  require_name "$name"
  run_make "NAME=$name" "$target"
}

internal_main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    create|new)
      cmd_create "$@"
      ;;
    shell|stop|clean|build|run|rebuild|heartbeat|heartbeat-stop|heartbeat-status|heartbeat-migrate)
      cmd_named_target "$cmd" "$@"
      ;;
    list)
      run_make list
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      echo "Unknown command: $cmd" >&2
      echo ""
      usage >&2
      exit 1
      ;;
  esac
}

run_in_supervisor() {
  ensure_supervisor
  supervisor_exec sandbox "$SUPERVISOR_PROJECT_ROOT/setup/oh" __internal "$@"
}

host_main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    install)
      cmd_install
      ;;
    bootstrap)
      cmd_bootstrap
      ;;
    supervisor)
      cmd_supervisor "$@"
      ;;
    help|-h|--help)
      usage
      ;;
    create|new|shell|stop|clean|build|run|rebuild|list|heartbeat|heartbeat-stop|heartbeat-status|heartbeat-migrate)
      run_in_supervisor "$cmd" "$@"
      ;;
    *)
      echo "Unknown command: $cmd" >&2
      echo ""
      usage >&2
      exit 1
      ;;
  esac
}

main() {
  local cmd="${1:-help}"

  case "$cmd" in
    __internal)
      shift || true
      internal_main "$@"
      ;;
    *)
      if [[ "${OH_SUPERVISOR:-}" == "1" ]]; then
        internal_main "$@"
      else
        host_main "$@"
      fi
      ;;
  esac
}

main "$@"
