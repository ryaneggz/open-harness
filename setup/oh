#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
WORKTREE_ROOT="$REPO_ROOT/.worktrees"

usage() {
  cat <<'EOF'
Open Harness CLI

Usage:
  oh install
  oh bootstrap
  oh supervisor status
  oh create <name> [-i] [--docker] [--tag TAG] [--base-branch BRANCH] [--branch BRANCH]
  oh shell <name>
  oh stop <name>
  oh clean <name>
  oh build <name>
  oh run <name>
  oh rebuild <name>
  oh list
  oh heartbeat <name>
  oh heartbeat-stop <name>
  oh heartbeat-status <name>
  oh heartbeat-migrate <name>
  oh help

Options for create:
  -i, --interactive     Prompt for missing values
  --docker              Enable Docker socket mount
  --tag TAG             Image tag (default: latest)
  --base-branch BRANCH  Base branch for the sandbox worktree
  --branch BRANCH       Branch name for the sandbox worktree

Behavior:
  - The supervisor lives on the host; there is no supervisor container
  - Managed sandboxes always use git worktrees under .worktrees/<name>
  - Each sandbox mounts its managed worktree directly at ~ inside the container
  - External workspaces are intentionally rejected
EOF
}

run_make() {
  (cd "$REPO_ROOT" && make "$@")
}

require_docker() {
  if ! command -v docker >/dev/null 2>&1; then
    echo "Error: docker is required on the host." >&2
    exit 1
  fi

  if ! docker info >/dev/null 2>&1; then
    echo "Error: Docker daemon is not reachable. Start Docker and try again." >&2
    exit 1
  fi
}

require_git_repo() {
  if ! git -C "$REPO_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "Error: $REPO_ROOT is not a git worktree. Open Harness sandboxes require git worktrees under .worktrees/." >&2
    exit 1
  fi
}

validate_name() {
  local name="$1"
  if [[ ! "$name" =~ ^[A-Za-z0-9][A-Za-z0-9_.-]*$ ]]; then
    echo "Error: invalid sandbox name '$name'. Use only letters, numbers, dot, underscore, and dash." >&2
    exit 1
  fi
}

require_name() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    echo "Error: sandbox name is required." >&2
    exit 1
  fi
  validate_name "$name"
}

prompt_yes_no() {
  local prompt="$1"
  local default="${2:-y}"
  local answer

  if [[ "$default" == "y" ]]; then
    read -rp "$prompt [Y/n]: " answer
    [[ -z "$answer" || "$answer" =~ ^[Yy]$ ]]
  else
    read -rp "$prompt [y/N]: " answer
    [[ "$answer" =~ ^[Yy]$ ]]
  fi
}

cmd_install() {
  chmod +x "$REPO_ROOT/setup/oh"

  local global_target="/usr/local/bin/oh"
  local user_bin="$HOME/.local/bin"
  local user_target="$user_bin/oh"

  if [[ -w /usr/local/bin ]]; then
    ln -sf "$REPO_ROOT/setup/oh" "$global_target"
    echo "Installed: $global_target -> $REPO_ROOT/setup/oh"
    return
  fi

  if sudo -n true 2>/dev/null; then
    sudo ln -sf "$REPO_ROOT/setup/oh" "$global_target"
    echo "Installed: $global_target -> $REPO_ROOT/setup/oh"
    return
  fi

  echo "/usr/local/bin is not writable and passwordless sudo is unavailable."

  if [[ -t 0 && -t 1 ]]; then
    echo "Choose an install location:"
    echo "  1) ~/.local/bin/oh (recommended)"
    echo "  2) Try sudo install to /usr/local/bin/oh"
    echo "  3) Cancel"

    local choice
    read -rp "Install method [1/2/3]: " choice

    case "${choice:-1}" in
      2)
        if sudo ln -sf "$REPO_ROOT/setup/oh" "$global_target"; then
          echo "Installed: $global_target -> $REPO_ROOT/setup/oh"
          return
        fi
        echo "Falling back to ~/.local/bin/oh"
        ;;
      3)
        echo "Cancelled."
        exit 1
        ;;
    esac
  fi

  mkdir -p "$user_bin"
  ln -sf "$REPO_ROOT/setup/oh" "$user_target"
  echo "Installed: $user_target -> $REPO_ROOT/setup/oh"

  if [[ ":$PATH:" != *":$user_bin:"* ]]; then
    echo ""
    echo "Add ~/.local/bin to your PATH if needed:"
    echo '  export PATH="$HOME/.local/bin:$PATH"'
  fi
}

cmd_bootstrap() {
  require_docker
  require_git_repo
  mkdir -p "$WORKTREE_ROOT"

  echo "Host supervisor ready"
  echo "  Repo root:      $REPO_ROOT"
  echo "  Worktree root:  $WORKTREE_ROOT"
  echo "  Workspace mount inside sandboxes: ~"
}

cmd_supervisor() {
  local subcmd="${1:-status}"
  shift || true

  case "$subcmd" in
    up)
      cmd_bootstrap
      ;;
    status)
      require_git_repo
      echo "Supervisor mode: host"
      echo "Repo root: $REPO_ROOT"
      echo "Managed worktree root: $WORKTREE_ROOT"
      if command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
        echo "Docker daemon: reachable"
      else
        echo "Docker daemon: unavailable"
      fi
      ;;
    down|stop)
      echo "Error: the supervisor runs on the host and has nothing to tear down." >&2
      exit 1
      ;;
    shell)
      echo "Error: the supervisor is the host-side 'oh' CLI; there is no separate supervisor shell." >&2
      exit 1
      ;;
    *)
      echo "Unknown supervisor command: $subcmd" >&2
      exit 1
      ;;
  esac
}

cmd_create() {
  local name=""
  local interactive=false
  local docker=false
  local tag="latest"
  local base_branch=""
  local branch=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -i|--interactive)
        interactive=true
        ;;
      -w|--workspace)
        echo "Error: external workspaces are not supported. Sandboxes must use managed git worktrees under .worktrees/<name>." >&2
        exit 1
        ;;
      --docker)
        docker=true
        ;;
      --tag)
        shift
        tag="${1:-latest}"
        ;;
      --base-branch)
        shift
        base_branch="${1:-}"
        ;;
      --branch)
        shift
        branch="${1:-}"
        ;;
      --seed|--no-seed)
        echo "Error: seeding external workspaces is no longer supported. Managed worktrees already contain the project scaffold." >&2
        exit 1
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        if [[ -z "$name" ]]; then
          name="$1"
        else
          echo "Unknown argument: $1" >&2
          exit 1
        fi
        ;;
    esac
    shift || true
  done

  if [[ "$interactive" == true && -z "$name" ]]; then
    read -rp "Sandbox name: " name
  fi

  if [[ "$interactive" == true ]]; then
    if prompt_yes_no "Enable Docker socket access?" "n"; then
      docker=true
    fi
  fi

  require_name "$name"
  cmd_bootstrap >/dev/null

  local args=("NAME=$name" "TAG=$tag")
  [[ "$docker" == true ]] && args+=("DOCKER=true")
  [[ -n "$base_branch" ]] && args+=("BASE_BRANCH=$base_branch")
  [[ -n "$branch" ]] && args+=("BRANCH=$branch")

  run_make "${args[@]}" quickstart
}

cmd_named_target() {
  local target="$1"
  shift
  local name="${1:-}"
  require_name "$name"
  require_docker
  run_make "NAME=$name" "$target"
}

cmd_list_host() {
  echo ""
  echo "  Running containers:"
  if ! command -v docker >/dev/null 2>&1; then
    echo "  docker is not installed on the host"
  elif ! docker info >/dev/null 2>&1; then
    echo "  Docker daemon is not reachable"
  else
    docker ps --filter "label=com.docker.compose.service=sandbox" --format "table {{.Names}}\t{{.Status}}\t{{.Image}}"
  fi

  echo ""
  echo "  Worktrees:"
  if git -C "$REPO_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    git -C "$REPO_ROOT" worktree list
  else
    echo "  $REPO_ROOT is not a git worktree"
  fi
  echo ""
}

dispatch_main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    install)
      cmd_install
      ;;
    bootstrap)
      cmd_bootstrap
      ;;
    supervisor)
      cmd_supervisor "$@"
      ;;
    create|new)
      cmd_create "$@"
      ;;
    shell|stop|clean|build|run|rebuild|heartbeat|heartbeat-stop|heartbeat-status|heartbeat-migrate)
      cmd_named_target "$cmd" "$@"
      ;;
    list)
      cmd_list_host
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      echo "Unknown command: $cmd" >&2
      echo ""
      usage >&2
      exit 1
      ;;
  esac
}

main() {
  local cmd="${1:-help}"

  case "$cmd" in
    __internal)
      shift || true
      dispatch_main "$@"
      ;;
    *)
      dispatch_main "$@"
      ;;
  esac
}

main "$@"
